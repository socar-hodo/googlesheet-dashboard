# === NextAuth.js 설정 ===
# openssl rand -base64 32 로 생성
AUTH_SECRET=

# Google Cloud Console → API 및 서비스 → 사용자 인증 정보에서 발급
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# === 접근 허용 이메일 목록 (쉼표 구분) ===
# 비어있으면 모든 Google 계정 허용 (개발 모드)
ALLOWED_EMAILS=user1@gmail.com,user2@gmail.com

# === Google Sheets 연동 (선택사항) ===
# 설정하지 않으면 목(mock) 데이터로 동작합니다
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# === BigQuery 연동 (선택사항) ===
# 설정하지 않으면 BigQuery 쿼리 결과 대신 null을 반환합니다 (lib/bigquery.ts)
# 생성 방법:
#   gcloud auth application-default login
#   base64 -w 0 ~/.config/gcloud/application_default_credentials.json
GOOGLE_APPLICATION_CREDENTIALS_B64=

# === 워크히스토리 시트 설정 (선택사항) ===
GOOGLE_WORK_HISTORY_SHEET_NAME=WorkHistory
GOOGLE_WORK_HISTORY_RANGE=WorkHistory!A1:Z1000

# === 카카오맵 SDK (존 시뮬레이터 페이지) ===
# 카카오 개발자 콘솔 → 앱 → 플랫폼 → JavaScript 키
NEXT_PUBLIC_KAKAO_JS_KEY=
